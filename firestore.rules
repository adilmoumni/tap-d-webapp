rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Usernames (uniqueness reservation) ──
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      // No updates — delete old + create new to change username
    }

    // ── Bio pages ──
    match /biopages/{bioId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if (request.auth != null && resource.data.ownerId == request.auth.uid)
        || (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'totalClicks', 'iosClicksTotal', 'androidClicksTotal', 'desktopClicksTotal', 'countriesTotal',
             'totalViews', 'iosViewsTotal', 'androidViewsTotal', 'desktopViewsTotal', 'viewCountriesTotal'
           ]));
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Links subcollection
      match /links/{linkId} {
        allow read: if true;
        // Only allow clicks field and breakdowns increment from anyone (for the click API)
        // Full writes require ownership
        allow update: if request.auth == null
          ? (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks', 'iosClicks', 'androidClicks', 'desktopClicks', 'countries']))
          : (get(/databases/$(database)/documents/biopages/$(bioId)).data.ownerId == request.auth.uid);
        allow create: if request.auth != null
          && getAfter(/databases/$(database)/documents/biopages/$(bioId)).data.ownerId == request.auth.uid;
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/biopages/$(bioId)).data.ownerId == request.auth.uid;
      }

      // Stats subcollection (daily aggregates — written by click API)
      match /stats/{date} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/biopages/$(bioId)).data.ownerId == request.auth.uid;
        allow write: if true;  // click tracking writes from server API route — open
      }
    }

    // ── Legacy bio_pages collection ──
    match /bio_pages/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Smart links ──
    match /links/{linkId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;

      // Per-link daily stats
      match /stats/{date} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/links/$(linkId)).data.uid == request.auth.uid;
        allow write: if true;  // click tracking writes from server
      }
    }

    // ── Click events ──
    match /clicks/{clickId} {
      allow read: if request.auth != null;
      allow create: if true;  // server-side click logging
    }

    // ── View events ──
    match /views/{viewId} {
      allow read: if request.auth != null;
      allow create: if true;  // server-side view logging
    }

    // ── Blog posts ──
    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    match /blogs/{blogId} {
      // Anyone can read published posts (public blog pages)
      allow read: if resource.data.status == 'published'
                  || (request.auth != null && isAdmin());

      // Only admins can create, update, or delete blog posts
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}

