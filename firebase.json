{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "out",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/links/**",
        "destination": "/links/placeholder.html"
      },
      {
        "source": "/d/links/**",
        "destination": "/d/links/placeholder.html"
      },
      {
        "source": "**",
        "destination": "/placeholder.html"
      }
    ]
  }
}
